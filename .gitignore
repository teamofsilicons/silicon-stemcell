venv/

__pycache__/
*.pyc
*.pyo
*.pyd

# Interface runtime state (contains local trust, rooms, media, watermarks)
core/interface_state/

# Worker outputs (generated at runtime)
worker/outputs/*.txt
worker/outputs/_active_workers.json
worker/outputs/_browser_queue.json
worker/outputs/_worker_registry.json

# Session files (generated at runtime)
sessions/

# Runtime state
.restart_pending
.glass_agent.pid
.glass-push.pid
*.tar.gz
.DS_Store
.silicon-upstream/

# Daily activity logs (generated at runtime; backed up via .backupsilicon)
logs/
